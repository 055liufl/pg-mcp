# PostgreSQL Configuration
PG_HOST=localhost
PG_PORT=5432
PG_USER=readonly_user
PG_PASSWORD=your_password_here
PG_DATABASES=
PG_EXCLUDE_DATABASES=template0,template1,postgres
PG_SSLMODE=prefer
PG_SSLROOTCERT=

# Connection Pool
DB_POOL_SIZE=5
STRICT_READONLY=false

# OpenAI Configuration
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=

# Query Limits
QUERY_TIMEOUT=30
MAX_ROWS=1000
MAX_CELL_BYTES=4096
MAX_RESULT_BYTES=10485760
MAX_RESULT_BYTES_HARD=52428800
SESSION_WORK_MEM=64MB
SESSION_TEMP_FILE_LIMIT=256MB
MAX_CONCURRENT_REQUESTS=20

# AI Result Validation (disabled by default)
ENABLE_VALIDATION=false
VALIDATION_SAMPLE_ROWS=10
VALIDATION_DATA_POLICY=metadata_only
VALIDATION_DENY_LIST=
VALIDATION_CONFIDENCE_THRESHOLD=-1.0

# Schema Cache
SCHEMA_REFRESH_INTERVAL=600
SCHEMA_MAX_TABLES_FOR_FULL_CONTEXT=50
MAX_RETRIES=2

# Redis
REDIS_URL=redis://localhost:6379/0

# Server
LOG_LEVEL=INFO
SSE_HOST=0.0.0.0
SSE_PORT=8000
